<https://w3id.org/np/RANokmO9j8qIxyBdirmYlJ_zKFtlQiWgeA86AavxiO-is/assertion> {
    <urn:pkg:platonic:P1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <urn:pkg:TestableHypothesis> .
    <urn:pkg:platonic:P1> <http://www.w3.org/2000/01/rdf-schema#label> "Morphogenesis is goal-directed navigation" .
    <urn:pkg:platonic:P1> <http://purl.org/dc/terms/identifier> "P1" .
    <urn:pkg:platonic:P1> <http://www.w3.org/2000/01/rdf-schema#comment> "Development pursues a target anatomy with error correction: disturb the endpoint and the system re-navigates back to the same form (regulative development, regeneration)." .
    <urn:pkg:platonic:P1> <urn:pkg:proposedTest> "Perturb or remove tissue mid-development across taxa and measure whether the final anatomy is restored despite different starting states." .
    <urn:pkg:platonic:P1> <urn:pkg:hasPriorProbability> "0.8800"^^<http://www.w3.org/2001/XMLSchema#double> .
    <urn:pkg:platonic:P1> <urn:pkg:hasResolvability> "0.9000"^^<http://www.w3.org/2001/XMLSchema#double> .
}

